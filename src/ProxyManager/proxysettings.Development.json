{
  "ReverseProxy": {
    "Routes": {
      "apiRoute": {
        "ClusterId": "apiCluster",
        "Match": {
          "Path": "/api/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api" }
        ]
      },
      "ui-route": {
        "ClusterId": "ui-cluster",
        "AuthorizationPolicy": "AuthenticatedUsersOnly",
        "Match": {
          "Path": "/manage/{**catch-all}"
        },
        "Transforms": [
          { "BearerToken": "access_token" },
          { "RequestHeaderRemove": "Cookie" },
          { "RequestHeader": "X-Auth-Groups", "Append": "proxy-manager admins"}
        ]
      }
    },
    "Clusters": {
      "apiCluster": {
        "Destinations": {
          "local": {
            "Address": "https://localhost:5001/"
          }
        },
        "HealthCheck": {
          "Passive": {
            "Enabled": true,
            "Policy": "TransportFailureRate",
            "ReactivationPeriod": "00:01:00"
          }
        },
        "Metadata": {
          "TransportFailureRateHealthPolicy.RateLimit": "0.5"
        }
      },
      "ui-cluster": {
        "Destinations": {
          "local": {
            "Address": "http://localhost:3000/"
          }
        }
      }
    }
  }
}