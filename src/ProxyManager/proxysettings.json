{
  "ReverseProxy": {
    "Routes": {
      "apiRoute": {
        "ClusterId": "apiCluster",
        "Match": {
          "Path": "/api/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/api"
          }
        ]
      },
      "ui-route": {
        "ClusterId": "ui-cluster",
        "AuthorizationPolicy": "RequireAuthenticatedUser",
        "Match": {
          "Path": "/manage/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/manage" },
          { "RequestHeader": "X-Auth-Sub", "Set": "{auth.sub}" },
          { "RequestHeader": "X-Auth-Groups", "Set": "{auth.groups}" },
          { "RequestHeader": "Authorization", "Set": "Bearer {auth.access_token}" }
        ]
      }
    },
    "Clusters": {
      "apiCluster": {
        "Destinations": {
          "primary": {
            "Address": "http://proxymanager-api:5001/"
          }
        },
        "HealthCheck": {
          "Passive": {
            "Enabled": true,
            "Policy": "TransportFailureRate",
            "ReactivationPeriod": "00:01:00"
          }
        },
        "Metadata": {
          "TransportFailureRateHealthPolicy.RateLimit": "0.5"
        }
      },
      "ui-cluster": {
        "Destinations": {
          "primary": {
            "Address": "http://proxymanager-ui:3000/"
          }
        }
      }
    }
  }
}
